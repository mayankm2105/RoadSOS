# ─── Deployment Target: Render.com ────────────────────────────────────────
# Set all variables below in Render Dashboard → Environment tab
# Never commit actual values to Git

# ─── Core ─────────────────────────────────────────────────────────────────
ENVIRONMENT=development
LOG_LEVEL=INFO

# ─── Database ──────────────────────────────────────────────────────────────
SQLITE_DB_PATH=./data/roadsos_cache.db

# ─── Google APIs ───────────────────────────────────────────────────────────
GOOGLE_PLACES_API_KEY=
GOOGLE_GEOCODING_API_KEY=

# ─── AI ────────────────────────────────────────────────────────────────────
GEMINI_API_KEY=
GEMINI_MODEL=gemini-1.5-flash

# ─── Speech-to-Text ────────────────────────────────────────────────────────
WHISPER_MODEL=base

# ─── SOS Links ─────────────────────────────────────────────────────────────
SOS_BASE_URL=http://localhost:5173/sos/
SOS_LINK_TTL_HOURS=24

# ─── Admin ─────────────────────────────────────────────────────────────────
ADMIN_KEY=change-me-before-deploy

# ─── CORS ──────────────────────────────────────────────────────────────────
CORS_ORIGINS=http://localhost:5173,http://localhost:3000
